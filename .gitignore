# ========================================
# DrugXplain Project .gitignore (Fixed)
# ========================================

# Ignore raw datasets (STITCH, DrugBank, etc.)
data/raw/

# Ignore large processed and intermediate data files
# but allow important small CSVs
data/processed/graph_data.pt
data/processed/*.pt
data/processed/*.pth
data/processed/*.npy
data/processed/*.npz
data/processed/*.gz
data/processed/*.tar
data/processed/*.zip

# Keep small CSV results in processed/
!data/processed/*.csv

# Ignore logs, cache, and temp files
*.log
*.tmp
__pycache__/
*.pyc

# Ignore system or IDE-specific files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Allow placeholder files (like README) inside ignored dirs
!data/raw/README.md
!data/processed/README.md
